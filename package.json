{
  "name": "work-harvest",
  "version": "0.3.1",
  "private": true,
  "description": "Agent-neutral local work records and reporting harness",
  "type": "module",
  "bin": {
    "wh": "./bin/wh.js"
  },
  "scripts": {
    "wh": "node ./bin/wh.js",
    "wh:rust": "cargo run --quiet --package work-harvest-cli",
    "test": "node --test",
    "validate:examples": "node ./bin/wh.js validate --include-examples",
    "check": "node --check ./bin/wh.js && node --check ./src/cli.js && node --test && node ./bin/wh.js validate --include-examples",
    "desktop:dev": "pnpm --dir apps/desktop tauri dev",
    "desktop:build": "pnpm --dir apps/desktop tauri:build",
    "desktop:bundle:verify": "node ./scripts/verify-macos-bundle.mjs",
    "desktop:frontend:build": "pnpm --dir apps/desktop build",
    "rust:test": "cargo test --workspace",
    "rust:cli:build": "cargo build --release --package work-harvest-cli",
    "rust:cli:sidecar": "node ./scripts/prepare-tauri-sidecar.mjs",
    "check:all": "pnpm run check && pnpm run desktop:frontend:build && cargo test --workspace"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.9.0"
  }
}
