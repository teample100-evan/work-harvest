{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-harvest.local/schemas/checkpoint.schema.json",
  "title": "Work Harvest Checkpoint",
  "description": "마지막 체크포인트 이후의 작업 진행을 보존하는 append-only 기록",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "work_item_id",
    "project_id",
    "kind",
    "source",
    "captured_at",
    "work_period",
    "title",
    "summary",
    "status_after",
    "activities",
    "decisions",
    "verifications",
    "outcomes",
    "blockers",
    "next_steps",
    "evidence",
    "related_checkpoint_ids",
    "correction_of",
    "confidentiality"
  ],
  "properties": {
    "schema_version": {
      "enum": ["1.0", "1.1"]
    },
    "id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "work_item_id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "project_id": {
      "$ref": "./common.schema.json#/$defs/identifier"
    },
    "kind": {
      "type": "string",
      "enum": ["progress", "milestone", "final", "correction", "backfill"]
    },
    "source": {
      "$ref": "./common.schema.json#/$defs/source"
    },
    "captured_at": {
      "$ref": "./common.schema.json#/$defs/timestamp"
    },
    "work_period": {
      "$ref": "./common.schema.json#/$defs/workPeriod"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "summary": {
      "$ref": "./common.schema.json#/$defs/nonEmptyString"
    },
    "status_after": {
      "type": "string",
      "enum": ["planned", "in_progress", "blocked", "completed", "cancelled"]
    },
    "activities": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["summary", "rationale", "status"],
        "properties": {
          "summary": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "rationale": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "status": {
            "type": "string",
            "enum": ["proposed", "accepted", "superseded"]
          }
        }
      }
    },
    "verifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "description", "status", "command", "evidence_refs"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["test", "build", "lint", "manual", "measurement", "review", "other"]
          },
          "description": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "partial", "not_run"]
          },
          "command": {
            "type": ["string", "null"]
          },
          "method": {
            "type": "string",
            "enum": ["command", "artifact", "manual", "external"]
          },
          "observed_at": {
            "oneOf": [
              { "$ref": "./common.schema.json#/$defs/timestamp" },
              { "type": "null" }
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/nonEmptyString"
            }
          }
        }
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "impact", "evidence_refs"],
        "properties": {
          "description": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          },
          "impact": {
            "type": ["string", "null"]
          },
          "category": {
            "type": "string",
            "enum": ["user_impact", "product_change", "quality", "delivery", "operation", "record_maintenance"]
          },
          "reporting": {
            "type": "string",
            "enum": ["primary", "supporting", "excluded"]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/nonEmptyString"
            }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/nonEmptyString"
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commits", "pull_requests", "issues", "files", "commands", "urls"],
      "properties": {
        "commits": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 7,
            "maxLength": 64
          }
        },
        "pull_requests": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        },
        "issues": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        },
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        },
        "commands": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "./common.schema.json#/$defs/nonEmptyString"
          }
        },
        "urls": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "branch", "head_before", "head_after", "dirty"],
      "properties": {
        "repository": {
          "$ref": "./common.schema.json#/$defs/nonEmptyString"
        },
        "branch": {
          "type": ["string", "null"]
        },
        "head_before": {
          "type": ["string", "null"]
        },
        "head_after": {
          "type": ["string", "null"]
        },
        "dirty": {
          "type": ["boolean", "null"]
        }
      }
    },
    "external_states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "reference", "state", "observed_at", "url"],
        "properties": {
          "provider": { "type": "string", "minLength": 1, "maxLength": 64 },
          "reference": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "state": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "observed_at": { "$ref": "./common.schema.json#/$defs/timestamp" },
          "url": {
            "oneOf": [
              { "type": "string", "format": "uri" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reached_gate", "remaining_gates", "evidence_refs"],
      "properties": {
        "reached_gate": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
        "remaining_gates": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["development", "review", "qa", "release", "operational"] }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "related_checkpoint_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "./common.schema.json#/$defs/identifier"
      }
    },
    "correction_of": {
      "oneOf": [
        {
          "$ref": "./common.schema.json#/$defs/identifier"
        },
        {
          "type": "null"
        }
      ]
    },
    "confidentiality": {
      "type": "string",
      "enum": ["normal", "sensitive", "restricted"]
    }
  },
  "anyOf": [
    {
      "properties": {
        "activities": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    {
      "properties": {
        "decisions": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    {
      "properties": {
        "verifications": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    {
      "properties": {
        "outcomes": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    {
      "properties": {
        "blockers": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    {
      "properties": {
        "next_steps": {
          "type": "array",
          "minItems": 1
        }
      }
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "correction"
          }
        }
      },
      "then": {
        "properties": {
          "correction_of": {
            "$ref": "./common.schema.json#/$defs/identifier"
          }
        }
      },
      "else": {
        "properties": {
          "correction_of": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "final"
          }
        }
      },
      "then": {
        "properties": {
          "status_after": {
            "const": "completed"
          },
          "outcomes": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ]
}
