{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-harvest.local/schemas/common.schema.json",
  "title": "Work Harvest Common Definitions",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "temporalBoundary": {
      "oneOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "surface", "session_ref"],
      "properties": {
        "agent": {
          "type": "string",
          "enum": ["codex", "claude-code", "manual", "other"]
        },
        "surface": {
          "type": "string",
          "enum": ["desktop", "cli", "ide", "cloud", "unknown"]
        },
        "session_ref": {
          "oneOf": [
            {
              "$ref": "#/$defs/nonEmptyString"
            },
            {
              "type": "null"
            }
          ]
        },
        "task_title": {
          "type": ["string", "null"]
        }
      }
    },
    "workPeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "precision", "basis"],
      "properties": {
        "start": {
          "$ref": "#/$defs/temporalBoundary"
        },
        "end": {
          "$ref": "#/$defs/temporalBoundary"
        },
        "precision": {
          "type": "string",
          "enum": ["exact", "day", "range", "unknown"]
        },
        "basis": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["checkpoint", "activity-event", "transcript", "git", "user", "unknown"]
          }
        },
        "timezone": {
          "type": "string",
          "default": "Asia/Seoul"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "precision": {
                "const": "unknown"
              }
            }
          },
          "then": {
            "properties": {
              "start": {
                "type": "null"
              },
              "end": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "precision": {
                "enum": ["exact", "day", "range"]
              }
            }
          },
          "then": {
            "properties": {
              "start": {
                "not": {
                  "type": "null"
                }
              },
              "end": {
                "not": {
                  "type": "null"
                }
              }
            }
          }
        }
      ]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "path": {
          "type": ["string", "null"]
        },
        "remote_url": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        },
        "default_branch": {
          "type": ["string", "null"]
        }
      }
    },
    "externalLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["issue", "pull-request", "document", "dashboard", "commit", "other"]
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "external_id": {
          "type": ["string", "null"]
        },
        "url": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "externalReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "external_id", "url", "role"],
      "properties": {
        "provider": { "type": "string", "minLength": 1, "maxLength": 64 },
        "external_id": { "$ref": "#/$defs/nonEmptyString" },
        "url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "role": {
          "type": "string",
          "enum": ["source", "delivery", "evidence", "related"]
        }
      }
    },
    "contextVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "status", "method", "source_ref", "observed_at"],
      "properties": {
        "description": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "type": "string", "enum": ["passed", "failed", "partial", "not_run"] },
        "method": { "type": "string", "enum": ["command", "artifact", "manual", "external"] },
        "source_ref": { "type": ["string", "null"] },
        "observed_at": {
          "oneOf": [
            { "$ref": "#/$defs/timestamp" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
