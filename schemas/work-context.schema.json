{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-harvest.local/schemas/work-context.schema.json",
  "title": "Work Harvest Work Context",
  "description": "새 세션 인수인계를 위한 업무 항목의 현재 상태",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_item_id",
    "project_id",
    "updated_at",
    "last_checkpoint_id",
    "last_verified_git_ref",
    "current_state",
    "decisions",
    "files",
    "verification",
    "next_steps",
    "risks",
    "git"
  ],
  "properties": {
    "schema_version": { "enum": ["1.0", "1.1"] },
    "work_item_id": { "$ref": "./common.schema.json#/$defs/identifier" },
    "project_id": { "$ref": "./common.schema.json#/$defs/identifier" },
    "updated_at": { "$ref": "./common.schema.json#/$defs/timestamp" },
    "last_checkpoint_id": {
      "oneOf": [
        { "$ref": "./common.schema.json#/$defs/identifier" },
        { "type": "null" }
      ]
    },
    "last_verified_git_ref": { "type": ["string", "null"] },
    "current_state": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_gate", "current_gate", "external_state", "remaining_gates", "observed_at"],
      "properties": {
        "target_gate": { "type": ["string", "null"] },
        "current_gate": { "type": ["string", "null"] },
        "external_state": { "type": ["string", "null"] },
        "remaining_gates": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "observed_at": {
          "oneOf": [
            { "$ref": "./common.schema.json#/$defs/timestamp" },
            { "type": "null" }
          ]
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "description"],
        "properties": {
          "path": { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
          "description": { "type": ["string", "null"] }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completed", "pending"],
      "properties": {
        "completed": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
              { "$ref": "./common.schema.json#/$defs/contextVerification" }
            ]
          }
        },
        "pending": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "./common.schema.json#/$defs/nonEmptyString" },
              { "$ref": "./common.schema.json#/$defs/contextVerification" }
            ]
          }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
    },
    "risks": {
      "type": "array",
      "items": { "$ref": "./common.schema.json#/$defs/nonEmptyString" }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "branch", "commit", "checked_at"],
      "properties": {
        "repository": { "type": ["string", "null"] },
        "branch": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "checked_at": {
          "oneOf": [
            { "$ref": "./common.schema.json#/$defs/timestamp" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
